# Required: path to a Beads-enabled git repository
BEADS_PROJECT_PATH=/path/to/your/beads-enabled/project

# Optional: explicit path to bv binary (if not on PATH)
BV_PATH=

# Optional: polling interval in ms (default 30000)
POLL_INTERVAL_MS=30000

# Optional: Anthropic API key for AI title cleanup on quick-create
# Without this, bead titles are saved as-is (no cleanup)
ANTHROPIC_API_KEY=
